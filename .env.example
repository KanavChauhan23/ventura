# ─────────────────────────────────────────────────────────────────────────────
#  Ventura AI — Environment Variables
#  Copy this file to .env and fill in your values
#  ALL AI keys below are 100% FREE — no credit card needed
# ─────────────────────────────────────────────────────────────────────────────

# App
ENV=development
SECRET_KEY=change-me-run-openssl-rand-hex-32

# ── FREE AI Keys ──────────────────────────────────────────────────────────────

# 1. GROQ (PRIMARY — recommended, totally free, blazing fast)
#    Sign up  : https://console.groq.com
#    Click    : API Keys → Create API Key
#    Free     : very generous limits, no hard cap for normal usage
GROQ_API_KEY=gsk_your_groq_key_here

# Which Groq model to use (all completely free):
#   llama3-70b-8192       <- best quality output  recommended
#   llama3-8b-8192        <- fastest responses
#   mixtral-8x7b-32768    <- great for structured JSON output
#   gemma2-9b-it          <- Google model on Groq infra
LLM_PROVIDER=groq
LLM_MODEL=llama3-70b-8192

# 2. GOOGLE GEMINI (FALLBACK — also free)
#    Sign up  : https://aistudio.google.com
#    Click    : Get API Key -> Create API key in new project
#    Free     : gemini-1.5-flash = 60 req/min | gemini-1.5-pro = 2 req/min
#    To switch: set LLM_PROVIDER=gemini
GOOGLE_API_KEY=AIza_your_google_key_here
GEMINI_MODEL=gemini-1.5-flash

# ── FREE Web Search for Market Research Agent (optional) ─────────────────────
# Tavily searches the real web inside the Market Research Agent
# Sign up  : https://tavily.com
# Free     : 1000 searches/month, no credit card needed
TAVILY_API_KEY=tvly_your_tavily_key_here

# ── FREE LangSmith Tracing (optional) ────────────────────────────────────────
# Visual dashboard showing every step your AI agents take
# Sign up  : https://smith.langchain.com
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=lsv2_your_langsmith_key_here

# ── Database ──────────────────────────────────────────────────────────────────
# Development: SQLite (zero setup, works out of the box)
DATABASE_URL=sqlite+aiosqlite:///./ventura.db

# Production on Render — paste Internal Database URL from Render dashboard:
# DATABASE_URL=postgresql+asyncpg://user:pass@host:5432/ventura_ai

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Frontend ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000

# ─────────────────────────────────────────────────────────────────────────────
#  QUICK START — only 2 steps needed:
#  [1] Get free Groq key  ->  https://console.groq.com
#  [2] Add it here        ->  GROQ_API_KEY=gsk_...
#  Everything else is optional. Run: docker-compose up --build
# ─────────────────────────────────────────────────────────────────────────────
